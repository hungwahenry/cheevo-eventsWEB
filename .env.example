# Base URL of the cheevo API including the /api/v1 prefix.
# Use Valet (cheevo.test) so the backend handles HTTP Range requests for video flyers.
#   Local dev (Valet):  http://cheevo.test/api/v1
#   Production:         https://api.cheevo.app/api/v1
CHEEVO_API_URL=http://cheevo.test/api/v1

# Sentry — create a Next.js project named "cheevo-web" in the "issorite" org.
# NEXT_PUBLIC_SENTRY_DSN is shipped to the browser; SENTRY_AUTH_TOKEN is build-only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
